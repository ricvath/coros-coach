{
  "name": "coros-coach",
  "version": "1.0.0",
  "description": "AI coaching layer for COROS smartwatches — training data, HRV, VO2max, lap splits, and coaching nudges",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    }
  },
  "keywords": ["coros", "running", "triathlon", "coaching", "hrv", "training"],
  "author": "ricvath",
  "license": "MIT",
  "homepage": "https://github.com/ricvath/coros-coach#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ricvath/coros-coach.git"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.750.0",
    "app-root-path": "3.1.0",
    "axios": "1.7.9",
    "coros-connect": "^0.1.7",
    "dayjs": "1.11.13",
    "jszip": "3.10.1",
    "ky": "1.7.2"
  }
}
